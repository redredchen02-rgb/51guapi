{
	"name": "51guapi-monorepo",
	"private": true,
	"type": "module",
	"scripts": {
		"setup": "pnpm install",
		"dev:extension": "pnpm --filter 51guapi-extension dev",
		"dev:backend": "pnpm --filter 51guapi-backend dev",
		"dev:webui": "pnpm --filter 51guapi-webui dev",
		"build:extension": "pnpm --filter 51guapi-extension build",
		"build:backend": "pnpm --filter 51guapi-backend build",
		"build:webui": "pnpm --filter 51guapi-webui build",
		"preview:webui": "pnpm --filter 51guapi-webui preview",
		"test": "pnpm -r test",
		"coverage": "pnpm -r --parallel coverage",
		"compile": "pnpm -r compile",
		"preflight": "tsx --import ./scripts/preflight/wxt-imports-register.mjs scripts/preflight/runner.ts",
		"test:preflight": "vitest run --config vitest.preflight.config.ts",
		"lint": "biome check --write",
		"lint:ci": "biome ci --diagnostic-level=error .",
		"format": "biome format --write",
		"check": "biome check",
		"postinstall": "git config core.hooksPath scripts/git-hooks",
		"eval:golden": "bash scripts/eval-golden.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@vitest/coverage-v8": "^4.1.8",
		"jsdom": "^29.1.1",
		"tsx": "^4.19.2",
		"vitest": "^4.1.8"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"better-sqlite3"
		],
		"overrides": {
			"esbuild": "^0.28.1",
			"shell-quote": "^1.8.4",
			"tmp": "^0.2.6",
			"uuid": "^11.1.1"
		}
	},
	"version": "0.3.0.0",
	"engines": {
		"node": ">=22",
		"pnpm": ">=9"
	}
}
