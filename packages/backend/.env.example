# 吃瓜小帮手 Backend Configuration

PORT=3002
HOST=127.0.0.1

# Keep this empty in example. Copy to .env and fill in your real OpenAI / DeepSeek / API Key
LLM_API_KEY=your_llm_api_key_here
LLM_ENDPOINT=https://la-sealion.inaiai.com/v1

# Optional overrides: if set, these will override client-sent models
# LLM_MODEL=gemma4-31b-heretic

# Data directory (SQLite pending.db + JSON prompt/gossip-site stores live here).
# GUAPI_DATA_DIR: override the data dir. Default: packages/backend/data.
# Legacy name PUBLISHER_DATA_DIR is still honored as a fallback for existing deploys.
# GUAPI_DATA_DIR=

# CORS: REQUIRED — fail-closed, server refuses to start if missing or set to '*'.
# Set to the extension's chrome-extension://<id>. The id is FIXED by the pinned
# EXTENSION_KEY in wxt.config.ts (dev == prod, no env override in CI/release),
# so a single value suffices. Verify in chrome://extensions after loading.
CORS_ORIGIN=chrome-extension://iljimdgfajpgnmanklehhmapojbcjecd

# JWT Authentication (fail-closed: server refuses to start on weak/placeholder JWT_SECRET)
# JWT_SECRET: 32+ char random. Generate:
#   node -e "console.log(require('node:crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# 自用模式(plan 2026-06-18-003):免密登入,无需 JWT_ADMIN_PASSWORD_HASH。

# SSRF allowlist (可爬取渠道白名单)
# 默认渠道 51cg1.com 由迁移种子写入 channels 表;新增渠道在扩展 UI 里直接添加(无需口令)。
# ALLOWED_HOSTS 为可选的额外 env 基线(与 channels 表取并集),逗号分隔,支持精确 host 与
# 通配 *.domain.com;留空 = fail-closed(仅靠 channels 表)。
# ALLOWED_HOSTS=

# Scraper scheduler. Scheduler only starts when LLM_ENDPOINT + LLM_API_KEY are set.
# 抓取站点由 scraperConfig.addSiteConfig 配置（详情页或列表发现模式）;
# 站点 host 须包含在上方 ALLOWED_HOSTS 内（fail-closed）。
# SCRAPER_LIST_BUDGET: 列表发现模式下每轮 cron 最多处理的新 URL 数（默认 20）
# SCRAPER_LIST_BUDGET=20

# Web search enrichment (free DuckDuckGo search, no API key needed)
# 当 ENRICHMENT_ENABLED=true 时，抓取后自动搜索补充资讯（评测/讨论/背景资料）
# ENRICHMENT_ENABLED=false 则跳过富化步骤
ENRICHMENT_ENABLED=true
# 每个作品最多搜索次数（默认 3，范围 1-10，防止触发反爬）
ENRICHMENT_MAX_QUERIES=3

# Quality gate (内容质量门禁)
# 质量分低于此阈值时显示警告（默认 0.6，范围 0-1）
# QUALITY_THRESHOLD=0.6

# 吃瓜入池前验证关阈值 (plan 004;全部可选,未设即用内置默认。免改代码调参)
# 据 /api/v1/metrics 的 guapi_gossip_verify_total{outcome} 分布调整:
#   GOSSIP_MIN_BODY_LEN: 正文有效长度下限,低于此硬拒(默认 80)。rejected 率高→调小。
#   GOSSIP_QUALITY_RATIO: 核心事实填充比例软标阈值(默认 0.5,范围 0-1)。
#   GOSSIP_NAME_THRESHOLD: 當事人(人名)grounding 重叠阈值(默认 0.8,范围 0-1)。
#   GOSSIP_NARRATIVE_THRESHOLD: 叙事字段 grounding 重叠阈值(默认 0.3,范围 0-1)。
#   GOSSIP_INVALID_MARKERS: 无效页特征(逗号分隔,覆盖默认集),如 404,not found,页面不存在。
#   GOSSIP_WINDOW_DAYS_DEFAULT: 未在请求传 windowDays 时的默认时间窗(天);不设=不按时间过滤。
#   GOSSIP_FINGERPRINT_FIELDS: 内容指纹参与字段(逗号分隔,覆盖默认集)。可选键:當事人,事件摘要,起因,經過,結果。
#     默认=當事人,事件摘要,起因,結果。suspected_duplicate 误判高→加字段(更严,更少撞);漏判→减字段。
#     ⚠改字段集会让旧指纹与新指纹失配,去重以新基重新开始(不回溯既有 pending 条目)。无效键静默忽略。
# GOSSIP_MIN_BODY_LEN=80
# GOSSIP_QUALITY_RATIO=0.5
# GOSSIP_NAME_THRESHOLD=0.8
# GOSSIP_NARRATIVE_THRESHOLD=0.3
# GOSSIP_INVALID_MARKERS=
# GOSSIP_WINDOW_DAYS_DEFAULT=
# GOSSIP_FINGERPRINT_FIELDS=當事人,事件摘要,起因,結果

# Telegram alert channel (one-way push, R26)
# TG_BOT_TOKEN: get from @BotFather. Format: numeric_id:secret (35+ char secret).
# TG_CHAT_ID: your personal chat ID or a group/channel ID (can be negative for groups).
# When TG_ENABLED=true, TG_BOT_TOKEN and TG_CHAT_ID are required (fail-closed).
TG_ENABLED=false
TG_BOT_TOKEN=
TG_CHAT_ID=

# launchd daemon (macOS auto-start, R29a)
# Install: bash scripts/launchd/install.sh   (requires pnpm build:backend first)
# The daemon loads secrets from ~/.51guapi/.env — MUST be chmod 600.
# Create: mkdir -p ~/.51guapi && cp packages/backend/.env.example ~/.51guapi/.env
#         # edit the file, then: chmod 600 ~/.51guapi/.env
# GUAPI_ENV_PATH: override the .env path if needed (default: ~/.51guapi/.env)
